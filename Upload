<script>
  const input = document.getElementById('videoInput');
  const chosen = document.getElementById('fileChosen');
  const dropZone = document.getElementById('dropZone');

  input.addEventListener('change', () => {
    if (input.files[0]) {
      const size = (input.files[0].size / (1024*1024)).toFixed(1);
      chosen.style.display = 'block';
      chosen.textContent = '✅ ' + input.files[0].name + ' (' + size + ' MB)';
    }
  });

  ['dragover','dragenter'].forEach(e => dropZone.addEventListener(e, ev => {
    ev.preventDefault(); dropZone.classList.add('dragover');
  }));
  ['dragleave','drop'].forEach(e => dropZone.addEventListener(e, () => {
    dropZone.classList.remove('dragover');
  }));

  document.getElementById('uploadForm').addEventListener('submit', () => {
    document.getElementById('progressWrap').style.display = 'block';
    document.getElementById('submitBtn').disabled = true;
    document.getElementById('submitBtn').textContent = 'Uploading...';
    // Fake progress for UX
    let p = 0;
    const bar = document.getElementById('uploadProgress');
    const iv = setInterval(() => {
      p = Math.min(p + Math.random() * 8, 90);
      bar.style.width = p + '%';
      if (p >= 90) clearInterval(iv);
    }, 300);
  });
</script>

{% endblock %}
